# Resume RAG - Environment Variables Configuration
# Copy this file to .env and update with your actual values

# Model Configuration
EMBEDDING_MODEL_NAME=all-MiniLM-L6-v2
EMBEDDING_MODEL_PATH=./models

# Vector Database Configuration
VECTOR_DB_PATH=./vector_db/chroma_db
CHROMA_COLLECTION_NAME=resume_collection

# Text Processing Configuration
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# PDF Processing Configuration
PDF_DIRECTORY=./resumes
MAX_PDF_SIZE_MB=50

# Logging Configuration
LOG_LEVEL=INFO
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s

# Feature Flags (For future use by other team members)
# ENABLE_RETRIEVAL=true
# ENABLE_LLM=false
# ENABLE_UI=false
